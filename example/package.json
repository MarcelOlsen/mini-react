{
	"name": "mini-react-showcase",
	"version": "1.0.0",
	"description": "Showcase application for MiniReact library using ElysiaJS",
	"type": "module",
	"scripts": {
		"dev": "bun run build && bun run --watch src/server.ts",
		"build": "bun build src/app.tsx --outdir=public --target=browser",
		"build:prod": "bun build src/app.tsx --outdir=public --target=browser --minify",
		"start": "bun run build:prod && bun run src/server.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format .",
		"check": "biome check .",
		"lint:write": "biome lint --write .",
		"format:write": "biome format --write .",
		"check:write": "biome check --write ."
	},
	"dependencies": {
		"elysia": "^1.1.29"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@biomejs/biome": "^1.9.4"
	}
}
